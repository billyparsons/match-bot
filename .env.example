# Anthropic auth — choose ONE, or leave both commented if you're logged in via `claude`
# The token from `claude` login is auto-read from ~/.claude/.credentials.json
# (kept fresh automatically — no manual updates needed)

# Option A: Claude Code OAuth token (manual override)
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...

# Option B: Standard API key (from console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — override signal-cli URL (default: http://127.0.0.1:8080)
# SIGNAL_CLI_URL=http://127.0.0.1:8080

# Optional — enable web_search (stub until set)
# BRAVE_API_KEY=BSA...
